<?xml version="1.0"?>
<!-- A simple humanoid (~1.75 m, ~74 kg) for PHX ragdoll demos: box pelvis,
     torso and feet, a sphere head and capsule limbs (<capsule> is a common
     vendor extension of URDF; the length attribute is the cylindrical part
     of the shape). Standing pose with arms in a T-pose so that no two
     non-adjacent shapes overlap at start. The pelvis is the root link; its
     frame sits at the pelvis centre, 1.0 m above the soles of the feet.
     All joints are passive revolute hinges (PHX imports URDF robots
     without motors). -->
<robot name="box_human">

  <material name="shirt">
    <color rgba="0.85 0.33 0.10 1.0"/>
  </material>
  <material name="pants">
    <color rgba="0.25 0.35 0.60 1.0"/>
  </material>
  <material name="skin">
    <color rgba="0.94 0.78 0.62 1.0"/>
  </material>
  <material name="shoe">
    <color rgba="0.20 0.20 0.20 1.0"/>
  </material>

  <!-- ============================== torso ============================== -->

  <link name="pelvis">
    <inertial>
      <mass value="10"/>
      <inertia ixx="0.1297" ixy="0" ixz="0" iyy="0.0813" iyz="0" izz="0.1443"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.24 0.34 0.20"/>
      </geometry>
      <material name="pants"/>
    </visual>
  </link>

  <joint name="spine" type="revolute">
    <origin xyz="0 0 0.10"/>
    <parent link="pelvis"/>
    <child link="torso"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="0" velocity="10"/>
  </joint>

  <link name="torso">
    <inertial>
      <origin xyz="0 0 0.25"/>
      <mass value="28"/>
      <inertia ixx="0.8857" ixy="0" ixz="0" iyy="0.7177" iyz="0" izz="0.4368"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25"/>
      <geometry>
        <box size="0.24 0.36 0.50"/>
      </geometry>
      <material name="shirt"/>
    </visual>
  </link>

  <joint name="neck" type="revolute">
    <origin xyz="0 0 0.52"/>
    <parent link="torso"/>
    <child link="head"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="0" velocity="10"/>
  </joint>

  <link name="head">
    <inertial>
      <origin xyz="0 0 0.14"/>
      <mass value="5"/>
      <inertia ixx="0.0288" ixy="0" ixz="0" iyy="0.0288" iyz="0" izz="0.0288"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.14"/>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <material name="skin"/>
    </visual>
  </link>

  <!-- ============================== arms =============================== -->
  <!-- Capsules are modeled along the z axis, so the arm visuals are turned
       onto the y axis by the rpy of their origin. -->

  <joint name="shoulder_l" type="revolute">
    <origin xyz="0 0.23 0.44"/>
    <parent link="torso"/>
    <child link="upper_arm_l"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="0" velocity="10"/>
  </joint>

  <link name="upper_arm_l">
    <inertial>
      <origin xyz="0 0.15 0"/>
      <mass value="2"/>
      <inertia ixx="0.0139" ixy="0" ixz="0" iyy="0.0016" iyz="0" izz="0.0139"/>
    </inertial>
    <visual>
      <origin xyz="0 0.15 0" rpy="1.5707963 0 0"/>
      <geometry>
        <capsule radius="0.04" length="0.20"/>
      </geometry>
      <material name="shirt"/>
    </visual>
  </link>

  <joint name="elbow_l" type="revolute">
    <origin xyz="0 0.30 0"/>
    <parent link="upper_arm_l"/>
    <child link="forearm_l"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.6" upper="0" effort="0" velocity="10"/>
  </joint>

  <link name="forearm_l">
    <inertial>
      <origin xyz="0 0.14 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.0096" ixy="0" ixz="0" iyy="0.0009" iyz="0" izz="0.0096"/>
    </inertial>
    <visual>
      <origin xyz="0 0.14 0" rpy="1.5707963 0 0"/>
      <geometry>
        <capsule radius="0.035" length="0.20"/>
      </geometry>
      <material name="skin"/>
    </visual>
  </link>

  <joint name="shoulder_r" type="revolute">
    <origin xyz="0 -0.23 0.44"/>
    <parent link="torso"/>
    <child link="upper_arm_r"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="0" velocity="10"/>
  </joint>

  <link name="upper_arm_r">
    <inertial>
      <origin xyz="0 -0.15 0"/>
      <mass value="2"/>
      <inertia ixx="0.0139" ixy="0" ixz="0" iyy="0.0016" iyz="0" izz="0.0139"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.15 0" rpy="1.5707963 0 0"/>
      <geometry>
        <capsule radius="0.04" length="0.20"/>
      </geometry>
      <material name="shirt"/>
    </visual>
  </link>

  <joint name="elbow_r" type="revolute">
    <origin xyz="0 -0.30 0"/>
    <parent link="upper_arm_r"/>
    <child link="forearm_r"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="2.6" effort="0" velocity="10"/>
  </joint>

  <link name="forearm_r">
    <inertial>
      <origin xyz="0 -0.14 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.0096" ixy="0" ixz="0" iyy="0.0009" iyz="0" izz="0.0096"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.14 0" rpy="1.5707963 0 0"/>
      <geometry>
        <capsule radius="0.035" length="0.20"/>
      </geometry>
      <material name="skin"/>
    </visual>
  </link>

  <!-- ============================== legs =============================== -->

  <joint name="hip_l" type="revolute">
    <origin xyz="0 0.09 -0.10"/>
    <parent link="pelvis"/>
    <child link="thigh_l"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.5" effort="0" velocity="10"/>
  </joint>

  <link name="thigh_l">
    <inertial>
      <origin xyz="0 0 -0.21"/>
      <mass value="7"/>
      <inertia ixx="0.1054" ixy="0" ixz="0" iyy="0.1054" iyz="0" izz="0.0148"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.21"/>
      <geometry>
        <capsule radius="0.065" length="0.28"/>
      </geometry>
      <material name="pants"/>
    </visual>
  </link>

  <joint name="knee_l" type="revolute">
    <origin xyz="0 0 -0.42"/>
    <parent link="thigh_l"/>
    <child link="shin_l"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.4" effort="0" velocity="10"/>
  </joint>

  <link name="shin_l">
    <inertial>
      <origin xyz="0 0 -0.20"/>
      <mass value="4"/>
      <inertia ixx="0.0532" ixy="0" ixz="0" iyy="0.0532" iyz="0" izz="0.0050"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.20"/>
      <geometry>
        <capsule radius="0.05" length="0.29"/>
      </geometry>
      <material name="pants"/>
    </visual>
  </link>

  <joint name="ankle_l" type="revolute">
    <origin xyz="0 0 -0.40"/>
    <parent link="shin_l"/>
    <child link="foot_l"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="0" velocity="10"/>
  </joint>

  <link name="foot_l">
    <inertial>
      <origin xyz="0.06 0 -0.04"/>
      <mass value="1"/>
      <inertia ixx="0.00137" ixy="0" ixz="0" iyy="0.00533" iyz="0" izz="0.00563"/>
    </inertial>
    <visual>
      <origin xyz="0.06 0 -0.04"/>
      <geometry>
        <box size="0.24 0.10 0.08"/>
      </geometry>
      <material name="shoe"/>
    </visual>
  </link>

  <joint name="hip_r" type="revolute">
    <origin xyz="0 -0.09 -0.10"/>
    <parent link="pelvis"/>
    <child link="thigh_r"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.5" effort="0" velocity="10"/>
  </joint>

  <link name="thigh_r">
    <inertial>
      <origin xyz="0 0 -0.21"/>
      <mass value="7"/>
      <inertia ixx="0.1054" ixy="0" ixz="0" iyy="0.1054" iyz="0" izz="0.0148"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.21"/>
      <geometry>
        <capsule radius="0.065" length="0.28"/>
      </geometry>
      <material name="pants"/>
    </visual>
  </link>

  <joint name="knee_r" type="revolute">
    <origin xyz="0 0 -0.42"/>
    <parent link="thigh_r"/>
    <child link="shin_r"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.4" effort="0" velocity="10"/>
  </joint>

  <link name="shin_r">
    <inertial>
      <origin xyz="0 0 -0.20"/>
      <mass value="4"/>
      <inertia ixx="0.0532" ixy="0" ixz="0" iyy="0.0532" iyz="0" izz="0.0050"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.20"/>
      <geometry>
        <capsule radius="0.05" length="0.29"/>
      </geometry>
      <material name="pants"/>
    </visual>
  </link>

  <joint name="ankle_r" type="revolute">
    <origin xyz="0 0 -0.40"/>
    <parent link="shin_r"/>
    <child link="foot_r"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="0" velocity="10"/>
  </joint>

  <link name="foot_r">
    <inertial>
      <origin xyz="0.06 0 -0.04"/>
      <mass value="1"/>
      <inertia ixx="0.00137" ixy="0" ixz="0" iyy="0.00533" iyz="0" izz="0.00563"/>
    </inertial>
    <visual>
      <origin xyz="0.06 0 -0.04"/>
      <geometry>
        <box size="0.24 0.10 0.08"/>
      </geometry>
      <material name="shoe"/>
    </visual>
  </link>

</robot>
