# Marketing material (large binaries: slide decks, videos) -- kept locally, not in the public repo
publications/

# Packaged toolbox build output (distributed via GitHub Releases, not tracked in git)
PHX Toolbox/release/

# MATLAB Project build cache
resources/**/.buildtool/

# MATLAB temporary / autosave files
*.asv
*.m~
*.autosave

# Simulink cache
slprj/
*.slxc

# Debug symbols (MEX build artifact, not shipped)
*.pdb

# Engine variant binaries -- not for public release (only the active io.mex* ships)
phx/+phx/+engine/bullet_*

# OS files
.DS_Store
Thumbs.db

# Internal / dev files -- not for the public repo
.claude/*
!.claude/skills/
backup/
*.bak
deploymentLog.html
CLAUDE.md
CODE_REVIEW.md

# NOTE: compiled MEX binaries (*.mexw64 / *.mexa64 / *.mexmaca64) are
# intentionally TRACKED -- they are shipped with the toolbox.
